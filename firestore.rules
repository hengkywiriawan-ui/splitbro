rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: own profile only. Login is gated on `approved`, but the gate is OPEN
    // by default — a new profile is created with approved=true so the user can log
    // in immediately. Admin REVOKES access by setting approved=false in the Firebase
    // console / Admin SDK; the user can never change `approved` on their own (update
    // rule below pins it), so a revoked user cannot flip themselves back.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.approved == true;
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.approved == resource.data.approved;
    }

    // Sessions: admin (creator) only — public share access goes through server route
    match /sessions/{sessionId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.adminId
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true;
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.adminId;

      // Restaurants subcollection
      match /restaurants/{restaurantId} {
        allow read, write: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/sessions/$(sessionId)).data.adminId;

        // Items subcollection (item_based mode only)
        match /items/{itemId} {
          allow read, write: if request.auth != null
            && request.auth.uid == get(/databases/$(database)/documents/sessions/$(sessionId)).data.adminId;
        }
      }

      // Shared costs subcollection
      match /sharedCosts/{costId} {
        allow read, write: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/sessions/$(sessionId)).data.adminId;
      }
    }
  }
}
